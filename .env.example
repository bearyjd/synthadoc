# .env.example — copy to .env and fill in your keys
# Never commit .env to git.

WIKI_NAME=main
WIKI_DOMAIN=Personal knowledge base
WIKI_PORT=7070

# LLM providers — set at least one
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional — enables web search ingestion
TAVILY_API_KEY=
