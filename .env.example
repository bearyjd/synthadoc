# .env.example — copy to .env and fill in your keys
# Never commit .env to git.

WIKI_NAME=main
WIKI_DOMAIN=Personal knowledge base
WIKI_PORT=7070

# Provider override — omit to use config.toml default (Gemini)
# Use claude-code to route through your local Claude Code session (no API key needed)
# Other options: anthropic, openai, groq
SYNTHADOC_PROVIDER=

# LLM providers — set at least one (not needed when SYNTHADOC_PROVIDER=claude-code)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional — enables web search ingestion
TAVILY_API_KEY=
